# ==========================================
# edu-arena-java 项目 .gitignore
# Java (Maven) + Python (agent-review-service)
# ==========================================

# ---------- IDE / 编辑器 ----------
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Java / Maven ----------
target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*

# ---------- Python 通用 ----------
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
.venv/
venv/
env/
ENV/

# 分发 / 构建
*.egg-info/
*.egg
dist/
build/
*.whl

# 测试 / 覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# 类型检查
.mypy_cache/
.pytype/

# Ruff / lint 缓存
.ruff_cache/

# ---------- agent-review-service 专属 ----------

# 环境变量（含密钥，只跟踪 .env.example）
agent-review-service/.env

# 作文原图（大二进制文件，不入库）
agent-review-service/picture/

# SQLite 任务状态库（运行时产物）
agent-review-service/data/*.sqlite
agent-review-service/data/*.db

# 批量运行结果（运行时产物）
agent-review-service/data/results*.jsonl

# 日志目录
agent-review-service/logs/

# RAG 向量库（运行时产物）
agent-review-service/data/chroma/
agent-review-service/data/vectordb/

# ---------- 其他 ----------
*.bak
*.tmp
*.temp
logs/
