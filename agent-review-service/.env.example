# ========== LLM 配置（复用 Java 平台 AiHubMix 网关）==========
AI_API_KEY=sk-LEc0CxRia23Ti4NqA1Ee05Be8c1a41E09c25DbEa30Db080e
AI_BASE_URL=https://api.aihubmix.com/v1
# 评审用模型（6 个维度 Agent 并行调用，需快且便宜；支持 thinking + structured_outputs）
AI_REVIEW_MODEL=gpt-5-mini
# 仲裁用模型（推荐更强的模型，负责综合 6 维度做最终裁决）
AI_ARBITRATOR_MODEL=gpt-5
# LLM 调用超时（秒）— gpt-5 推理可能较慢，适当放宽
AI_TIMEOUT=90
AI_MAX_RETRIES=3

# ========== 对战平台连接（离线批量系统使用）==========
ARENA_BASE_URL=http://8.219.130.23:5001
ARENA_USERNAME=admin
ARENA_PASSWORD=admin123

# ========== 评审服务自身 ==========
REVIEW_HOST=0.0.0.0
REVIEW_PORT=8100
REVIEW_URL=http://localhost:8100

# ========== RAG 向量库 ==========
CHROMA_DIR=./data/chroma
# embedding 提供方：openai | local_bge
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ========== 离线批量任务存储 ==========
BATCH_STORE_PATH=./data/batch_tasks.sqlite
BATCH_CONCURRENCY=3

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_DIR=./logs
