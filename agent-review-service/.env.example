# ========== LLM 配置（复用 Java 平台 AiHubMix 网关）==========
AI_API_KEY=sk-your-aihubmix-key
AI_BASE_URL=https://api.aihubmix.com/v1
# 评审用模型（支持多模态）
AI_REVIEW_MODEL=gpt-4o-mini
# 仲裁用模型（推荐更强的模型）
AI_ARBITRATOR_MODEL=gpt-4o
# LLM 调用超时（秒）
AI_TIMEOUT=60
AI_MAX_RETRIES=3

# ========== 对战平台连接（离线批量系统使用）==========
ARENA_BASE_URL=http://localhost:5001
ARENA_USERNAME=admin
ARENA_PASSWORD=admin123

# ========== 评审服务自身 ==========
REVIEW_HOST=0.0.0.0
REVIEW_PORT=8100
REVIEW_URL=http://localhost:8100

# ========== RAG 向量库 ==========
CHROMA_DIR=./data/chroma
# embedding 提供方：openai | local_bge
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ========== 离线批量任务存储 ==========
BATCH_STORE_PATH=./data/batch_tasks.sqlite
BATCH_CONCURRENCY=3

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_DIR=./logs
